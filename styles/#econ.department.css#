:root {
    --main-color: #91c34a;
    --main-color-dark: #77a437;
    --main-color-light: #aad470;
    --main-red: #dc6027;
    --main-red-light: #e38052;
    --main-red-lighter: #eaa07d;
    --main-blue: #30476b;
    --main-blue-light: #5175ad;
    --main-blue-lighter: #628ed1;
    --page-margin: 10px;
    --box-margin-left: 15px;
}

body {
    font-family: Arial, sans-serif;
    font-size: 16px;
}

.top-page {
    overflow: auto;
}

.econ {
    float: left;
    position: absolute;
    top: 48px;
    font-family: "Palantino Linotype", Palatino, serif;
    font-weight: bold;
    font-size: 19px;
}

.uzh {
    background-image: url("../images/university-logo.svg");
    background-repeat: no-repeat;
    background-size: 200px;
    padding-top: 40px;
    padding-left: 40px;
    padding-bottom: 50px;
    padding-right: 160px;
    float: right;
    top: 10px;
    right: 50px;
}

.page {
	border: 1px solid #cfcfcf;
    background-color: rgb(145, 195, 74, 0.05);
}

.header {
    height: 97px;
    background-color: var(--main-blue);
    display: flex;
    justify-content: space-between;
}

.header-title {
    padding: var(--page-margin);
    height: 100%;
    display: table;
}

.header-title .header-title-text {
    display: table-cell;
    vertical-align: middle;
}

.header-title-text h1 {
    margin-bottom: 0px;
    color: white;
    font-size: 34px;
}

.header-title strong {
    color: white;
    font-size: 16px;
}

.header-logo {
    background-image: url("../images/econ-logo-new.png");
    background-repeat: no-repeat;
    background-size: 100%;
    padding-top: 15px;
    padding-right: 50px;
    padding-bottom: 35px;
    padding-left: 50px;
}

.header-bottom {
    background-color: var(--main-color);
    height: 10px;
}

.main-container {
    margin: var(--page-margin);
}

.main-container a {
    color: black;
}

.bg-green {
    background-color: var(--main-color);
}

.bg-green .navbar-toggler {
    border-color: rgba(0, 0, 0, 0.4);
}

.navbar {
    padding: 0rem 1rem;
}

.navbar li {
    font-size: 13.5px;
    font-variant: small-caps;
}

.navbar-light .navbar-brand {
    color: white;
    margin-right: 0.5rem;
}

.navbar-light .navbar-nav .nav-link {
    color: var(--main-blue);
}

.navbar-light .navbar-nav .nav-link:hover {
    color: white;
} 

.navbar-light .navbar-nav .nav-link.active {
    color: white;
}

.unit-navbar {
    margin-bottom: 10px;
}

.navbar-brand {
    margin-right: .5 rem;
    min-height: 30px;
}

.icon-back {
    background-image: url("../images/back-button-blue.svg");
    background-repeat: no-repeat;
    background-size: 16px;
    min-height: 16px;
    padding: 8px;
    position: relative;
    top: 3.4px;
}

.icon-rating {
    background-image: url("../images/ratingstar.svg");
    background-repeat: no-repeat;
    background-size: 30px;
    min-height: 30px;
    padding: 5px;
    position: relative;
    left: 20px;
    top: 2.5px;
    bottom: 2px;
}


.icon-back:hover {
    background-image: url("../images/back-button-white.svg");
}

.module-box {
    margin-top: 15px;
    margin-bottom: 15px;
    overflow: hidden;
}

.module-box .image-box {
    overflow: hidden;
    width: 50%;
    float: left;
}

.image-box img {
    max-width: 100%;
    overflow: hidden;
    border-radius: 1px;
}

.module-box:hover img {
    opacity: 0.5;
    transition: 0.3s;
}

.module-box .text-box {
    width: 53%;
    float: right;
    padding-left: 10px;
    padding-top: 7px;
    padding-right: 10px;
    background-color: var(--main-color);
    text-align: right;
    margin-top: -10%;
    margin-right: 10px;
    border-radius: 1px;
}

.module-box .text-box h3{
    color: white;
    font-size: 22px;
    letter-spacing: ;
    font-weight: ;
    font-variant: small-caps;
}

.module-box .text-box p {
    color: black;
}

.module-box:hover h3, .module-box:hover p {
    color: var(--main-color-dark);
    transition: .3s ease-out;
}

.module-box:hover .text-box {
    opacity: 0.6;
    transition: 0.3s;
}

.module-box a {
    color: var(--main-color);
    text-decoration: none;
}

.hoverable:hover {
	box-shadow: 0 6px 10px 0 rgba(0, 0, 0, 0.2), 0 6px 20px 0 rgba(0, 0, 0, 0.1);
    transition: .3s ease-out;
	cursor: pointer;
}

.overview {
    padding-left: var(--page-margin);
    padding-right: var(--page-margin);
    padding-top: var(--page-margin);
}

.overview h2 {
    border-bottom: solid 1px #676767;
    font-size: 23px;
    color: black;
    font-weight: 500;
}

.box {
    min-height: 180px;
    margin-left: var(--box-margin-left);
    margin-right: var(--page-margin);
    margin-top: 5px;
    margin-bottom: 5px;
    overflow: auto;
    padding-right: 5px;
}

.box h3 {
    font-size: 18px;
    color: black;
}

.box ol {
    padding-inline-start: 2rem;
}

.box.hoverable-fancy:hover {
    margin-left: 0px;
    border-left: 8px solid var(--main-color);
    padding-left: calc(var(--box-margin-left) - 8px);
    box-shadow: 0 14px 28px rgba(0,0,0,0.25), 0 10px 10px rgba(0,0,0,0.22);
    transition: box-shadow 0.3s;
}

.hoverable-fancy:hover h3{
    color: var(--main-color);
    transition-duration: 0.3s;
}

.box-title {
    background-repeat: no-repeat;
    background-position: left;
    background-size: 37px;
    margin-top: 1rem;
    margin-bottom: 1rem;
