table.syllabus {
    margin-top: 10px;
    vertical-align: middle;
    text-align: left;
    width: 100%;
}

.news-entry {
    border-bottom: 3px solid var(--main-blue);
    margin-top: 0px;
    margin-bottom: 20px;
    padding-bottom: 20px;
}

.news-entry h2 {
    color: var(--main-blue);
    font-size: 28px;
    margin-top: 10px;
    margin-bottom: 10px;
}

.news-entry-meta {
    font-family: Georgia;
