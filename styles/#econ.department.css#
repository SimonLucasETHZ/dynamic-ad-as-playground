.box a {
    color: black;
}

.box p {
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
    padding-right: 4px;
}

.box td {
    padding-right: 5px;
}

.in-box-link a {
    color: var(--main-color);
}

.in-box-link a:hover {
    color: var(--main-color-dark);
}

a:hover {
    text-decoration: none;
}
.btn-primary {
    background-color: var(--main-color);
